@page
@model STASIS.Pages.LabSetup.StudiesModel
@{
    ViewData["Title"] = "Manage Studies";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<h5 class="mt-3">Add Study</h5>
<form method="post" asp-page-handler="Add" class="row g-2 mb-4">
    <div class="col-md-3">
        <input asp-for="Input.StudyCode" class="form-control" placeholder="Study code *" />
        <span asp-validation-for="Input.StudyCode" class="text-danger small"></span>
    </div>
    <div class="col-md-3">
        <input asp-for="Input.StudyName" class="form-control" placeholder="Study name" />
    </div>
    <div class="col-md-4">
        <input asp-for="Input.PrincipalInvestigator" class="form-control" placeholder="Principal Investigator" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Add</button>
    </div>
</form>

<h5>Existing Studies</h5>
@if (!Model.Studies.Any())
{
    <p class="text-muted">No studies defined yet.</p>
}
else
{
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>PI</th>
                <th style="width:180px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Studies)
            {
                <tr>
                    <td>@s.StudyCode</td>
                    <td>@(s.StudyName ?? "-")</td>
                    <td>@(s.PrincipalInvestigator ?? "-")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary"
                                data-bs-toggle="modal"
                                data-bs-target="#editModal"
                                data-id="@s.StudyID"
                                data-code="@s.StudyCode"
                                data-name="@s.StudyName"
                                data-pi="@s.PrincipalInvestigator">
                            Edit
                        </button>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@s.StudyID"
                              style="display:inline"
                              onsubmit="return confirm('Delete study @s.StudyCode?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Edit">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Study</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Input.StudyID" id="editId" />
                    <div class="mb-3">
                        <label class="form-label">Code *</label>
                        <input asp-for="Input.StudyCode" id="editCode" class="form-control" />
                        <span asp-validation-for="Input.StudyCode" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input asp-for="Input.StudyName" id="editName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Principal Investigator</label>
                        <input asp-for="Input.PrincipalInvestigator" id="editPi" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('editModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            document.getElementById('editId').value = btn.dataset.id;
            document.getElementById('editCode').value = btn.dataset.code;
            document.getElementById('editName').value = btn.dataset.name || '';
            document.getElementById('editPi').value = btn.dataset.pi || '';
        });
    </script>
}
